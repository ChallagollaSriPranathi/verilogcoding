//description for halfadder in data flow modelling
module half_adder(A,B,S,C);
input A,B;
output S,C;
assign S=(A^B);
assign C=(A&B);
endmodule



//In Gate level Modelling:
module half_adder ( input a,b,output sum, carry);
xor g1(sum, a, b); 
and g2(carry, a, b);
endmodule
//In Data Flow Modelling:
module half_adder(input a,b,output sum,carry);
assign sum=(a^b);
assign carry=(a&b);
endmodule
//In Behavioral Modelling:
module half_adder (input  a, b,output reg sum, carry);
    always @(*) begin
        sum   = a ^ b;   
        carry = a & b;
    end
endmodule
