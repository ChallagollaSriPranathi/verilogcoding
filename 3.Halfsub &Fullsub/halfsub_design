//description of half subtractor in data flow modelling
module half_sub(
    input A, B,
    output Diff, Borrow
);
    assign Diff=(A^B);
    assign Borrow=(~A)&B;
endmodule




//In Gate level Modelling:
module half_subtractor (input a,b,output diff,borrow);
wire w1;
w1=~a;
xor g1(diff, a, b); 
and g2(carry, w1, b);
endmodule
//In Data Flow Modelling:
module half_subtractor (input a,b,output diff,borrow);
assign diff=(a^b);
assign borrow=(~a&b);
endmodule
//In Behavioral Modelling:
module half_subtractor (input  a, b,output reg diff,borrow);
    always @(*) begin
        diff = a ^ b;   
        borrow = ~a & b;
    end
endmodule

